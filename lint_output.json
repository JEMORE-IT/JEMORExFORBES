    "source": "'use client';\n\nimport React from 'react';\n\nimport TimelineItem from '@/components/molecules/TimelineItem';\nimport TitleC from '@/components/molecules/TitleC';\n\nimport TimelineSectionProps from './index.types';\n\nconst TimelineSection: React.FC<TimelineSectionProps> = ({ events }) => {\n  return (\n    <section className=\"mx-auto flex w-full max-w-6xl flex-col items-center justify-center px-6 py-20 pb-32\">\n      <div className=\"mb-20 text-center\">\n        <TitleC\n          sottotitolo=\"THE PROGRAM\"\n          colored=\"Timeline\"\n          color=\"var(--tertiary-blue)\"\n          layout=\"center\"\n        >\n          Event Timeline\n        </TitleC>\n        <p className=\"mt-4 max-w-2xl text-white/70 text-center font-opensans\">\n          Scopri le attività previste per la giornata, dal check-in all'aperitivo finale.\n          Il programma potrebbe subire leggere variazioni.\n        </p>\n      </div>\n\n      <div className=\"relative w-full\">\n        {/* Linea verticale centrale per Desktop (collega tutta la timeline) */}\n        <div className=\"absolute left-8 md:left-1/2 top-0 h-full w-px -translate-x-1/2 bg-white/10 hidden md:block\"></div>\n        {/* Linea verticale per Mobile (collega tutta la timeline a sinistra) */}\n        <div className=\"absolute left-8 top-0 h-full w-px -translate-x-1/2 bg-white/10 block md:hidden\"></div>\n\n        <div className=\"flex flex-col w-full relative z-10 py-10\">\n          {events.map((event, index) => (\n            <TimelineItem\n              key={index}\n              time={event.time}\n              title={event.title}\n              description={event.description}\n              color={event.color}\n              align={index % 2 === 0 ? 'left' : 'right'}\n            />\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default TimelineSection;\n",
